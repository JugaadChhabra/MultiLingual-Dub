# --- Email notifications (Resend) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
NOTIFY_EMAILS=editor1@example.com,editor2@example.com

# --- NAS ---
NAS_MODE=local           # local | smb
NAS_ROOT_PATH=./nas_data # local: filesystem path | smb: subfolder within the share
NAS_SERVER=              # SMB only — e.g. 10.1.1.3
NAS_SHARE=               # SMB only — e.g. MediaStore
NAS_USERNAME=            # SMB only
NAS_PASSWORD=            # SMB only
NAS_DOMAIN=              # SMB only — leave blank if no domain
NAS_PORT=445             # SMB only
